{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SessionsImportParams",
  "type": "object",
  "required": [
    "backend"
  ],
  "properties": {
    "backend": {
      "type": "string"
    },
    "source_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "external_ids": {
      "description": "Specific external ids to import; `None` ⇒ every discovered session. Unknown ids are silently dropped so a stale TUI snapshot never wedges an import call.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    }
  }
}
