# WEK-73 / M4.1: pin schema goldens to LF so the round-trip test
# matches across the WEK-72 three-OS matrix. Git for Windows
# defaults to `core.autocrlf=true`, which otherwise rewrites these
# files to CRLF on checkout and breaks the byte-identical compare
# in `la-proto::tests::round_trip::schema_files_match_generated_output`.
docs/schema/*.json text eol=lf

# Source and templates the daemon ships verbatim — keep LF so test
# fixtures and rendered-output assertions stay byte-stable.
*.rs       text eol=lf
*.toml     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.plist    text eol=lf
*.xml      text eol=lf
*.service  text eol=lf
*.sh       text eol=lf
