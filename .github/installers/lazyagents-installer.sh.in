#!/bin/sh
# LazyAgents aggregator installer — chains the per-crate cargo-dist
# installers for la-daemon (`lad`) and la-tui (`la`). Generated by
# .github/workflows/release.yml at tag-cut time (release tag + version
# placeholders are substituted by the workflow's forge step). Do not
# edit the artifact attached to a release — edit the .in template
# instead. Source: .github/installers/lazyagents-installer.sh.in in
# https://github.com/TinyWhite1997/LazyAgents .
#
# `LAZYAGENTS_INSTALLER_TAG` and `LAZYAGENTS_INSTALLER_BASE_URL` mirror
# the `LAZYAGENTS_UPDATE_MANIFEST_URL` escape hatch used by `la
# --check-update`: set them when installing from a fork or an internal
# mirror, leave them unset for the canonical release.
set -e

APP_NAME="lazyagents"
APP_VERSION="__RELEASE_VERSION__"
TAG="${LAZYAGENTS_INSTALLER_TAG:-__RELEASE_TAG__}"
BASE="${LAZYAGENTS_INSTALLER_BASE_URL:-https://github.com/TinyWhite1997/LazyAgents/releases/download/${TAG}}"

# Pick a downloader once. We download to a temp file before exec'ing
# rather than piping straight to `sh` — a piped `curl | sh` swallows
# curl's exit status (the pipeline's status is `sh`'s), so a 404 or
# network failure would silently report "installed" with nothing
# actually written. POSIX sh has no `pipefail`, hence the temp file.
if command -v curl >/dev/null 2>&1; then
    fetch() { curl --proto '=https' --tlsv1.2 -fLsS -o "$2" "$1"; }
elif command -v wget >/dev/null 2>&1; then
    fetch() { wget -q -O "$2" "$1"; }
else
    echo "lazyagents-installer: need curl or wget on \$PATH" >&2
    exit 1
fi

tmp_dir=$(mktemp -d 2>/dev/null || mktemp -d -t lazyagents-installer)
trap 'rm -rf "$tmp_dir"' EXIT INT TERM

for crate in la-daemon la-tui; do
    url="${BASE}/${crate}-installer.sh"
    tmp="${tmp_dir}/${crate}-installer.sh"
    printf '==> %s: fetching %s\n' "$crate" "$url"
    if ! fetch "$url" "$tmp"; then
        echo "lazyagents-installer: failed to download $url" >&2
        exit 1
    fi
    printf '==> %s: running installer\n' "$crate"
    sh "$tmp"
done

printf '==> lazyagents %s installed (la + lad).\n' "$APP_VERSION"
