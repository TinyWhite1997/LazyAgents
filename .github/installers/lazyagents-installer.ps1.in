# LazyAgents aggregator installer — chains the per-crate cargo-dist
# installers for la-daemon (`lad`) and la-tui (`la`). Generated by
# .github/workflows/release.yml at tag-cut time; the placeholders below
# are substituted there. Source: .github/installers/lazyagents-installer.ps1.in
# in https://github.com/TinyWhite1997/LazyAgents .
$ErrorActionPreference = 'Stop'

$appName    = 'lazyagents'
$appVersion = '__RELEASE_VERSION__'

if ($env:LAZYAGENTS_INSTALLER_TAG) {
    $tag = $env:LAZYAGENTS_INSTALLER_TAG
} else {
    $tag = '__RELEASE_TAG__'
}

if ($env:LAZYAGENTS_INSTALLER_BASE_URL) {
    $base = $env:LAZYAGENTS_INSTALLER_BASE_URL
} else {
    $base = "https://github.com/TinyWhite1997/LazyAgents/releases/download/$tag"
}

foreach ($crate in @('la-daemon', 'la-tui')) {
    $url = "$base/$crate-installer.ps1"
    Write-Host "==> $crate`: installing from $url"
    Invoke-RestMethod -Uri $url | Invoke-Expression
}

Write-Host "==> $appName $appVersion installed (la + lad)."
