# Cargo build output
/target/
**/target/

# Cargo lock for libraries (LazyAgents ships binaries `lad` and `la`,
# so Cargo.lock SHOULD be committed — do not ignore it).

# sqlx offline query cache: keep `.sqlx/` checked in (CI builds without DB),
# ignore only the transient prepared payloads if any tool writes them here.
**/sqlx-data.json.tmp

# Test / coverage artifacts
*.profraw
*.profdata
/coverage/
/tarpaulin-report.*
/cobertura.xml
lcov.info

# Criterion / flamegraph
/criterion/
flamegraph.svg
perf.data
perf.data.old

# Local environment & secrets
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Local agent runtime data (only present if a dev points
# XDG_DATA_HOME at the repo; harmless to ignore by default)
/.lazyagents/state/
/.lazyagents/wt/
/.lazyagents/*.sqlite*
/.lazyagents/*.sock

# mdBook build output for the docs/ handbook
/docs/book/build/
